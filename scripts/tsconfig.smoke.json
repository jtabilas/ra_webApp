{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "../.smoke",
    "rootDir": "..",
    "strict": false,
    "noImplicitAny": false,
    "isolatedModules": false
  },
  "include": ["../lib/ra-parser/**/*.ts", "smoke-runner.ts"],
  "exclude": ["../node_modules", "../.next"]
}
